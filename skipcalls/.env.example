# SkipCalls environment variables
# Copy this file to .env and fill in your values.

# Twilio credentials (required for SMS alerts in future upgrades)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# Number to receive SMS summaries (future upgrade)
NOTIFY_PHONE_NUMBER=+15551111111

# App settings
PORT=8000
